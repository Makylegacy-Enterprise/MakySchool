# MakySchool local reverse proxy (started by npm run dev via dev:caddy).
#
# Entry URLs (port 8080 avoids sudo on Linux):
#   http://localhost:8080              tenant root (apps/web)
#   http://<school-slug>.localhost:8080   tenant school
#   http://myschool.localhost:8080     platform admin (apps/admin)
#
# API stays on localhost:4000 — Next.js rewrites /api/* via API_INTERNAL_URL.

{
	auto_https off
}

:8080 {
	@myschool host myschool.localhost
	handle @myschool {
		reverse_proxy localhost:3001
	}

	@tenant host *.localhost
	handle @tenant {
		reverse_proxy localhost:3000 {
			header_up X-School-Slug {labels.0}
		}
	}

	handle {
		reverse_proxy localhost:3000
	}
}

# MakySchool — single environment file (repo root)
# Copy to .env and fill in values. Optional local overrides: .env.local (gitignored)

# ── Tenant web (apps/web) ────────────────────────────────────────────────────
NEXT_PUBLIC_ROOT_DOMAIN=school.makylegacy.com
NEXT_PUBLIC_APP_URL=http://localhost:8080
NEXT_PUBLIC_PLATFORM_APP_URL=http://myschool.localhost:8080
NEXT_PUBLIC_API_URL=/api

# ── Platform admin (apps/admin) ──────────────────────────────────────────────
NEXT_PUBLIC_TENANT_APP_URL=http://localhost:8080
PLATFORM_APP_URL=http://myschool.localhost:8080

# ── API (Express) ────────────────────────────────────────────────────────────
PORT=4000
API_URL=http://localhost:4000
API_INTERNAL_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:8080,http://myschool.localhost:8080

# Simulate a tenant on plain localhost (optional)
# DEV_TENANT_SLUG=your-school-slug

# ── Database (Supabase) ──────────────────────────────────────────────────────
# URL-encode special characters in the password (# → %23) and wrap in quotes.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
# DATABASE_SSL=true

# ── Auth (API + Next.js middleware must share secrets) ───────────────────────
SUPERADMIN_JWT_SECRET=change-me-superadmin
TENANT_JWT_SECRET=change-me-tenant
SUPERADMIN_EMAIL=admin@makyschool.com
SUPERADMIN_PASSWORD=ChangeMe123!
SUPERADMIN_NAME=Platform Admin
# SUPERADMIN_FORCE_RESET=true

# ── Migrations ───────────────────────────────────────────────────────────────
# RUN_MIGRATIONS=true

# ── External integrations ────────────────────────────────────────────────────
SCHOOLPAY_WEBHOOK_SECRET=

# ── Billing (off until SchoolPay is implemented) ─────────────────────────────
# SUBSCRIPTIONS_ENABLED=true
# NEXT_PUBLIC_SUBSCRIPTIONS_ENABLED=true

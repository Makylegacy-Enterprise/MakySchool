# MakySchool — single environment file (repo root)
# Copy to .env and fill in values. Optional local overrides: .env.local (gitignored)

# ── Tenant web (apps/web) ────────────────────────────────────────────────────
NEXT_PUBLIC_ROOT_DOMAIN=school.makylegacy.com
NEXT_PUBLIC_APP_URL=http://localhost:8080
NEXT_PUBLIC_PLATFORM_APP_URL=http://myschool.localhost:8080
NEXT_PUBLIC_API_URL=/api

# ── Platform admin (apps/admin) ──────────────────────────────────────────────
NEXT_PUBLIC_TENANT_APP_URL=http://localhost:8080
PLATFORM_APP_URL=http://myschool.localhost:8080

# ── API (Express) ────────────────────────────────────────────────────────────
PORT=4000
API_URL=http://localhost:4000
API_INTERNAL_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:8080,http://myschool.localhost:8080
# Production: add your Vercel/production dashboard URLs (comma-separated).
# Wildcards supported, e.g. https://*.vercel.app
# CORS_ORIGIN=https://school.makylegacy.com,https://*.vercel.app
# Or allow any *.vercel.app preview without listing each deployment:
# CORS_ALLOW_VERCEL_PREVIEWS=true

# Simulate a tenant on plain localhost (optional)
# DEV_TENANT_SLUG=your-school-slug

# ── Database (Supabase) ──────────────────────────────────────────────────────
# URL-encode special characters in the password (# → %23) and wrap in quotes.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
# DATABASE_SSL=true

# ── Auth (API + Next.js middleware must share secrets) ───────────────────────
SUPERADMIN_JWT_SECRET=change-me-superadmin
TENANT_JWT_SECRET=change-me-tenant
SUPERADMIN_EMAIL=admin@makyschool.com
SUPERADMIN_PASSWORD=ChangeMe123!
SUPERADMIN_NAME=Platform Admin
# SUPERADMIN_FORCE_RESET=true

# Central Auth (Supabase-backed auth service — shared across MakyLegacy products)
# When set, tenant login/password flows use the external auth API instead of local hashes only.
AUTH_SERVICE_URL=https://auth.makylegacy.com
NEXT_PUBLIC_AUTH_API_URL=https://auth.makylegacy.com/api/v1
NEXT_PUBLIC_AUTH_SUPABASE_URL=https://your-project.supabase.co
AUTH_SUPABASE_URL=
AUTH_SUPABASE_SERVICE_ROLE_KEY=

# ── Migrations ───────────────────────────────────────────────────────────────
# RUN_MIGRATIONS=true

# ── External integrations ────────────────────────────────────────────────────
SCHOOLPAY_WEBHOOK_SECRET=

# MakyPay (Mobile Money billing — API server only, never expose to Next.js public env)
MAKYWIRE_API_BASE_URL=https://wire-api.makylegacy.com/api/v1
MAKYWIRE_API_KEY=
MAKYWIRE_API_SECRET=
# Or paste the pre-encoded value from MakyPay dashboard → Developers → API Keys:
# MAKYWIRE_AUTH_BASIC=
MAKYWIRE_CALLBACK_URL=
MAKYWIRE_WEBHOOK_SECRET=

# ── Email (forgot password flow) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
SMTP_FROM="MakySchool <noreply@makylegacy.com>"

# SUBSCRIPTIONS_ENABLED=true
# NEXT_PUBLIC_SUBSCRIPTIONS_ENABLED=true

# ── Rate limiting (API — slowapi + Redis) ────────────────────────────────────
# Local Redis: docker compose -f docker-compose.redis.yml up -d
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_ENABLED=true
# fixed-window | moving-window | sliding-window-counter
RATE_LIMIT_STRATEGY=fixed-window
RATE_LIMIT_KEY_PREFIX=makyschool:rl

# ── Object storage (Wasabi S3-compatible) ────────────────────────────────────
STORAGE_BACKEND=local
# STORAGE_BACKEND=wasabi
# WASABI_ACCESS_KEY=
# WASABI_SECRET_KEY=
# WASABI_BUCKET=makyschool
# WASABI_REGION=eu-west-3
# WASABI_ENDPOINT_URL=https://s3.eu-west-3.wasabisys.com
# STORAGE_PRESIGNED_TTL_SECONDS=3600
# UPLOAD_DIR=apps/api/uploads

# ── Marketing site (apps/marketing — school.makylegacy.com) ────────────────────
NEXT_PUBLIC_SITE_URL=https://school.makylegacy.com
# Google Search Console HTML tag — content value only (see apps/marketing/GOOGLE_SEARCH_CONSOLE.md)
# GOOGLE_SITE_VERIFICATION=

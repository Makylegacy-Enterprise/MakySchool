# Public site URL (canonical links, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=https://school.makylegacy.com

# Google Search Console — HTML tag verification (recommended)
# 1. Add property at https://search.google.com/search-console
# 2. Choose "HTML tag" method and copy the content= value only (not the full meta tag)
# 3. Set below and redeploy; then click Verify in Search Console
GOOGLE_SITE_VERIFICATION=
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=   # use if verifying at build time on Vercel

# Bing Webmaster Tools (optional) — meta msvalidate.01 content value
# BING_SITE_VERIFICATION=

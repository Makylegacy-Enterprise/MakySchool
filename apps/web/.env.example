# Copy to apps/web/.env.local for local development

# Public app URL and tenant routing
NEXT_PUBLIC_ROOT_DOMAIN=makyschool.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Browser uses same-origin /api (proxied to Express by next.config.ts)
NEXT_PUBLIC_API_URL=/api

# Express backend (must be running: npm run dev:api)
API_INTERNAL_URL=http://localhost:4000

# Simulate a tenant on plain localhost (optional)
# DEV_TENANT_SLUG=your-school-slug

# Must match TENANT_JWT_SECRET in root .env / apps/api for middleware route guards
TENANT_JWT_SECRET=dev-tenant-secret
